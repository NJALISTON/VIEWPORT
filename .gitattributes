# Normalize line endings to LF for all Godot and text files
*.gd text eol=lf
*.tscn text eol=lf
*.gdshader text eol=lf
*.cfg text eol=lf
*.godot text eol=lf
*.json text eol=lf
*.md text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig text eol=lf

# Binary file handling
*.png binary
*.import binary

# Exclude development and repository meta files from release ZIP downloads (for Asset Store)
/.gitattributes export-ignore
/.gitignore export-ignore
/.editorconfig export-ignore
/LICENSE export-ignore
/README.md export-ignore
